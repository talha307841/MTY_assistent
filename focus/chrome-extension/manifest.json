{
  "manifest_version": 3,
  "name": "FOCUS Companion",
  "version": "1.0.0",
  "description": "Send tab context and quick task actions to local FOCUS daemon.",
  "icons": {
    "16": "icons/focus.svg",
    "48": "icons/focus.svg",
    "128": "icons/focus.svg"
  },
  "permissions": ["tabs", "activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:7799/*", "http://localhost:7799/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FOCUS"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
